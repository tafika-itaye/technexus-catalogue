"breacrumbsPromise":__remixContext.p([{"name":"Home","slug":"/en-global"}])});__remixContext.a=3;</script><script nonce="6bc1b16b416e97a603ea78a9d02645bf" type="module" async="">import "https://cdn.shopify.com/oxygen-v2/32964/22247/46102/3235371/assets/manifest-8afdd063.js";
